YOUTUBE_API_KEY=your-youtube-api-key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Runtime
RUN_ONCE=true
INTERVAL_MINUTES=1440

# Daily quota budget to consume before stopping the run
MAX_DAILY_QUOTA_UNITS=9500

# Query discovery / crawl settings
SEARCH_PAGE_SIZE=50
CRAWL_PAGE_SIZE=50
SEARCH_REGION_CODE=US
SEARCH_LANGUAGE=en
